      "parameters": {
        "jsCode": "// Detect instrument model numbers in each query and append them so\n// Pinecone semantic search boosts chunks where those tokens appear.\n// Processes ALL input items (one per dataset row).\n\nconst patterns = [\n  /\\b(1[0-9]{3}[A-Z]?)\\b/g,\n  /\\b(7[0-9]{3}[A-Z]?)\\b/g,\n  /\\b(6[0-9]{3}[A-Z]?)\\b/g,\n  /\\b(8[0-9]{3}[A-Z]?)\\b/g,\n  /\\b(ZORBAX[\\s\\-]?[\\w]*)\\b/gi,\n  /\\b(Poroshell[\\s\\-]?[\\w]*)\\b/gi,\n  /\\b(InfinityLab[\\s\\-]?[\\w]*)\\b/gi,\n  /\\b(Infinity\\s?II?)\\b/gi,\n  /\\b(MassHunter)\\b/gi,\n  /\\b(OpenLAB)\\b/gi,\n  /\\b(ChemStation)\\b/gi,\n  /\\b(TripleQuad[\\s\\-]?[\\w]*)\\b/gi,\n  /\\b(QTOF[\\s\\-]?[\\w]*)\\b/gi\n];\n\nconst out = [];\nfor (const item of $input.all()) {\n  const input = item.json;\n  const query = input.chatInput || input.Query || input.text || input.message || '';\n\n  const found = new Set();\n  for (const p of patterns) {\n    for (const m of query.matchAll(p)) {\n      const val = m[1].trim().toUpperCase().replace(/\\s+/g, '_');\n      if (val.length >= 3) found.add(val);\n    }\n  }\n  const detected = Array.from(found);\n  const enrichedQuery = detected.length > 0 ? query + ' ' + detected.join(' ') : query;\n\n  out.push({\n    json: {\n      ...input,\n      chatInput: enrichedQuery,\n      detectedInstruments: detected\n    }\n  });\n}\n\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
