      "id": "49b403c3-e4f9-46a4-872c-399735224479",
      "name": "LLM Judge",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.3,
      "position": [
        320,
        0
      ],
      "credentials": {
        "openAiApi": {
          "id": "418azV3p8e3HXr1o",
          "name": "OpenAI account"
        }
