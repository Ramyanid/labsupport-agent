    {
      "parameters": {
        "jsCode": "// Read verdict from LLM Judge input; pull dataset row + answer from\n// 'Tag Answer' by index (Tag Answer is in this node's lineage and carries\n// id/Query/Category/Expected_namespace/output for each row, in order).\n\nfunction extractParsed(obj) {\n  if (obj == null) return null;\n  if (Array.isArray(obj.output) && obj.output[0] && Array.isArray(obj.output[0].content)) {\n    const t = obj.output[0].content[0] && obj.output[0].content[0].text;\n    if (t && typeof t === 'object') return t;\n    if (typeof t === 'string') {\n      try { return JSON.parse(t.replace(/```json|```/g, '').trim()); } catch (e) {}\n    }\n  }\n  if (typeof obj.verdict === 'string') return obj;\n  const candidates = [obj.output, obj.text, obj.content, obj.response,\n                      obj.message && obj.message.content];\n  for (const c of candidates) {\n    if (c && typeof c === 'object' && typeof c.verdict === 'string') return c;\n    if (typeof c === 'string') {\n      try {\n        const p = JSON.parse(c.replace(/```json|```/g, '').trim());\n        if (p && p.verdict) return p;\n      } catch (e) {}\n    }\n  }\n  return null;\n}\n\nconst scoreMap = { PASS: 1, PARTIAL: 0.5, FAIL: 0 };\nconst results = [];\nconst items = $input.all();\nconst tagged = $('Tag Answer').all();\n\nfor (let i = 0; i < items.length; i++) {\n  const j = items[i].json;\n\n  let parsed = extractParsed(j);\n  if (!parsed) {\n    parsed = { verdict: 'FAIL', namespace_ok: false,\n               reason: 'UNPARSEABLE_RAW: ' + JSON.stringify(j).slice(0, 300) };\n  }\n\n  const verdict = String(parsed.verdict || 'FAIL').toUpperCase();\n  const score = scoreMap[verdict] ?? 0;\n  const namespaceOk = parsed.namespace_ok === true || parsed.namespace_ok === 'true';\n\n  const row = tagged[i] ? tagged[i].json : {};\n\n  results.push({\n    json: {\n      id: row.id || '',\n      query: row.Query || '',\n      category: row.Category || '',\n      expected_namespace: row.Expected_namespace || '',\n      verdict: verdict,\n      score: score,\n      namespace_ok: namespaceOk,\n      reason: parsed.reason || '',\n      answer: row.output || '',\n      timestamp: new Date().toISOString()\n    }\n  });\n}\n\nreturn results;"
      },
